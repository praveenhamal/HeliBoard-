<LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

    <!-- Top row: optional pin icon + clip text -->
    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

        <ImageView
                android:id="@+id/clipboard_entry_pinned_icon"
                android:contentDescription="@string/clipboard_history_pinned_first"
                android:layout_width="@dimen/config_clipboard_pinned_icon_size"
                android:layout_height="@dimen/config_clipboard_pinned_icon_size"
                android:layout_marginVertical="8dp"
                android:layout_marginStart="4dp"/>

        <TextView
                android:id="@+id/clipboard_entry_content"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="2dp"
                android:layout_marginHorizontal="8dp"
                android:hapticFeedbackEnabled="false"
                android:soundEffectsEnabled="false"
                android:ellipsize="end"
                android:maxLines="4"/>

    </LinearLayout>

    <!-- Trigger label row — hidden when no trigger key is set -->
    <TextView
            android:id="@+id/clipboard_entry_trigger_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="4dp"
            android:textSize="10sp"
            android:textStyle="italic"
            android:alpha="0.7"
            android:maxLines="1"
            android:ellipsize="end"
            android:visibility="gone"/>

</LinearLayout>
