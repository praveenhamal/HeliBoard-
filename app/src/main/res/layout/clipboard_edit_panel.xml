    Edit panel shown above the keyboard when the user chooses "Edit clip"
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/clipboard_edit_panel"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp">

    <EditText
        android:id="@+id/clipboard_edit_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:background="@drawable/clipboard_edit_field_background"
        android:hint="@string/clipboard_edit_hint_text"
        android:inputType="textMultiLine"
        android:maxLines="3"
        android:minLines="1"
        android:imeOptions="flagNoExtractUi"
        android:padding="8dp"
        android:layout_marginBottom="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/clipboard_edit_trigger"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:background="@drawable/clipboard_edit_field_background"
            android:layout_weight="1"
            android:hint="@string/clipboard_edit_hint_trigger"
            android:inputType="textNoSuggestions"
            android:maxLines="1"
            android:imeOptions="flagNoExtractUi"
            android:padding="8dp"/>

        <Button
            android:id="@+id/clipboard_edit_confirm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/clipboard_edit_confirm"
            android:textSize="18sp"/>

    </LinearLayout>

</LinearLayout>
